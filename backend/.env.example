# =============================================================================
# MIMI AI CONFIGURATION
# Copy this file to .env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# MONGODB (Required)
# -----------------------------------------------------------------------------
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/

# Or MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mimidb?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# LLM API KEYS (At least one required)
# -----------------------------------------------------------------------------
# OpenAI (Recommended)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (Optional backup)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# -----------------------------------------------------------------------------
# YOUTUBE API (Optional - for video search feature)
# -----------------------------------------------------------------------------
# YOUTUBE_API_KEY=your-youtube-api-key-here

# -----------------------------------------------------------------------------
# TAVILY API (Optional - lets Mimi answer real-time questions: news, current events)
# Get a free key at https://tavily.com
# -----------------------------------------------------------------------------
# TAVILY_API_KEY=tvly-your-tavily-api-key-here

# Timezone used for "what's today's date / what time is it" answers (IANA name)
# MIMI_TIMEZONE=Asia/Kolkata

# -----------------------------------------------------------------------------
# JWT SECRET (Required for authentication)
# -----------------------------------------------------------------------------
# Generate a random secret key (use a password generator)
SECRET=your-secret-key-here-change-this-to-random-string

# -----------------------------------------------------------------------------
# MEMORY SYSTEM CONFIGURATION
# -----------------------------------------------------------------------------
# Basic Memory (Default - no additional setup)
USE_ADVANCED_MEMORY=false

# Advanced Memory Services (Optional - requires Docker services)
# Uncomment and set these if using advanced memory

# Redis (Working Memory)
# REDIS_URL=redis://localhost:6379/0

# PostgreSQL (Semantic Memory)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/mimidb

# Qdrant (Episodic & Knowledge Memory)
# QDRANT_URL=http://localhost:6333

# -----------------------------------------------------------------------------
# OPTIONAL SETTINGS
# -----------------------------------------------------------------------------
# Skip LLM health check on startup (faster startup for development)
# SKIP_LLM_HEALTHCHECK=false

# Flask environment
# FLASK_ENV=development

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. Never commit this file with real API keys to git
# 2. Keep your SECRET key truly secret and random
# 3. For production, use strong passwords for PostgreSQL
# 4. MongoDB Atlas free tier is available at https://www.mongodb.com/cloud/atlas
# 5. OpenAI API key from https://platform.openai.com/api-keys
