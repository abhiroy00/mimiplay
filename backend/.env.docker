# Docker Compose Environment Variables
# Copy this to .env when using docker-compose

# MongoDB (Required)
MONGODB_URI=mongodb://localhost:27017/
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mimidb

# LLM API Keys (Required - at least one)
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# YouTube API (Optional)
# YOUTUBE_API_KEY=your-youtube-key

# JWT Secret (Required)
SECRET=change-this-to-random-secret

# Performance Features (Recommended)
USE_CELERY=true
ENABLE_RESPONSE_CACHE=true

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# PostgreSQL Configuration (for advanced memory)
POSTGRES_PASSWORD=mimipass
DATABASE_URL=postgresql://postgres:mimipass@postgres:5432/mimidb

# Qdrant Configuration (for advanced memory)
QDRANT_URL=http://qdrant:6333

# Advanced Memory (Optional)
USE_ADVANCED_MEMORY=false

# Celery Configuration (Optional)
CELERY_WORKERS=4

# Note: When using docker-compose, service names (redis, postgres, qdrant)
# are used instead of localhost
