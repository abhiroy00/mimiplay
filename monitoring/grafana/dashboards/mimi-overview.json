{
  "title": "Mimi Backend Overview",
  "uid": "mimi-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["mimi", "flask", "celery"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(flask_http_request_total{service=\"mimi-backend\"}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (5xx %)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * sum(rate(flask_http_request_total{status=~\"5..\",service=\"mimi-backend\"}[1m])) / sum(rate(flask_http_request_total{service=\"mimi-backend\"}[1m]))",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 Latency (ms)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1000 },
            { "color": "red", "value": 3000 }
          ]
        }
      },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by(le) (rate(flask_http_request_duration_seconds_bucket{service=\"mimi-backend\"}[5m]))) * 1000",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Requests",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "flask_http_request_active{service=\"mimi-backend\"}",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate by Endpoint",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by(endpoint) (rate(flask_http_request_total{service=\"mimi-backend\"}[1m]))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Response Time Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum by(le) (rate(flask_http_request_duration_seconds_bucket{service=\"mimi-backend\"}[5m]))) * 1000",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by(le) (rate(flask_http_request_duration_seconds_bucket{service=\"mimi-backend\"}[5m]))) * 1000",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum by(le) (rate(flask_http_request_duration_seconds_bucket{service=\"mimi-backend\"}[5m]))) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Status Codes",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by(status) (rate(flask_http_request_total{service=\"mimi-backend\"}[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Redis Connected Clients",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "redis_connected_clients{service=\"redis\"}",
          "legendFormat": "connected clients"
        },
        {
          "datasource": "Prometheus",
          "expr": "redis_commands_processed_total{service=\"redis\"}",
          "legendFormat": "commands/s"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Celery Tasks",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "flower_tasks_total",
          "legendFormat": "total tasks"
        },
        {
          "datasource": "Prometheus",
          "expr": "flower_workers_online",
          "legendFormat": "workers online"
        }
      ]
    }
  ]
}
